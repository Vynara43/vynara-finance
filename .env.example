# ═══ VYNARA FINANCE – Environment Configuration ═══════════════════════════════
# Copier ce fichier en .env et remplir les valeurs (ne pas committer le fichier .env)

# ─ DATABASE (Neon PostgreSQL) ─────────────────────────────────────────────────
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST:5432/neondb?sslmode=require&channel_binding=require

# ─ CONTACT & COMMUNICATION ─────────────────────────────────────────────────────
CONTACT_EMAIL=contact@vynara-finance.cfd
WHATSAPP_NUMBER=+33612345678

# ─ SMTP CONFIGURATION (envoi d'emails) ──────────────────────────────────────────
SMTP_HOST=mail.vynara-finance.cfd
SMTP_PORT=587
SMTP_USER=contact@vynara-finance.cfd
SMTP_PASS=your_smtp_password

# ─ ADMIN PASSWORD (modifiez-le !) ───────────────────────────────────────────────
# Générez un nouveau mot de passe sécurisé et remplacez la valeur
ADMIN_PASSWORD=change_me_to_secure_password

# ─ SITE SETTINGS ────────────────────────────────────────────────────────────────
SITE_NAME=VYNARA FINANCE
SITE_DOMAIN=vynara-finance.cfd
SITE_URL=https://vynara-finance.cfd
